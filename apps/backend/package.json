        "better-auth": "^1.6.23",
        "dotenv": "^17.4.2",
        "drizzle": "^1.4.0",
        "drizzle-orm": "^0.44.7",
        "hono": "^4.12.27",
        "pg": "^8.22.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^20.11.17",
        "tsc-alias": "^1.9.1",
        "tsx": "^4.7.1",
        "typescript": "^5.8.3"

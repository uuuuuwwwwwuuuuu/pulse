{
    "name": "@bookio/backend",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && tsc-alias",
        "typecheck": "tsc --noEmit",
        "start": "node dist/index.js"
    },
    "types": "./src/routes/index.ts",

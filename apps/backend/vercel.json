{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "hono",
    "installCommand": "cd ../.. && pnpm install",
    "buildCommand": "cd ../.. && pnpm --filter @bookio/db build && pnpm --filter @bookio/backend build",
    "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ./ ../../packages/db",
    "functions": {
        "server.js": {
            "includeFiles": "dist/**"
        }
    }
}

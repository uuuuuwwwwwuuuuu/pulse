{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "vite",
    "installCommand": "cd ../.. && pnpm install",
    "buildCommand": "pnpm run build",
    "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ./ ../../packages/ui ../../apps/backend",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://bookio-backend.vercel.app/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}

